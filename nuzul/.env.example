# --- Database ---
# Local dev: point both at the same Postgres.
# Supabase (staging/prod):
#   DATABASE_URL = Connection pooling string (PgBouncer, port 6543):
#     postgresql://postgres.<ref>:<pwd>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require
#   DIRECT_URL   = Direct connection (port 5432), used for migrations:
#     postgresql://postgres.<ref>:<pwd>@aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=require
DATABASE_URL="postgresql://nuzul:nuzul@127.0.0.1:5432/nuzul?schema=public"
DIRECT_URL="postgresql://nuzul:nuzul@127.0.0.1:5432/nuzul?schema=public"

# --- Auth (JWT session signing) ---
AUTH_SECRET="change-me-to-a-long-random-string-min-32-chars"
SESSION_COOKIE="nuzul_session"

# --- Payments ---
# active provider for the deposit flow: mock | satim | edahabia | baridimob
PAYMENT_PROVIDER="mock"
# commission (platform take-rate) and deposit ratio (share of total paid online)
PLATFORM_COMMISSION_RATE="0.12"
DEPOSIT_RATE="0.20"
SERVICE_FEE_RATE="0.05"

# --- Notifications (Web Push / VAPID) ---
# generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:ops@nuzul.dz"
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""

# --- Media storage (Supabase Storage) ---
# Create a PUBLIC bucket in Supabase (default name "listings"). Photo uploads go through
# /api/uploads using the SERVICE ROLE key (server-only — never expose to the browser).
SUPABASE_URL="https://<ref>.supabase.co"
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_STORAGE_BUCKET="listings"

# --- App ---
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_DEFAULT_LOCALE="ar"
