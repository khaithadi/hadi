# --- Database ---
DATABASE_URL="postgresql://nuzul:nuzul@127.0.0.1:5432/nuzul?schema=public"

# --- Auth (JWT session signing) ---
AUTH_SECRET="change-me-to-a-long-random-string-min-32-chars"
SESSION_COOKIE="nuzul_session"

# --- Payments ---
# active provider for the deposit flow: mock | satim | edahabia | baridimob
PAYMENT_PROVIDER="mock"
# commission (platform take-rate) and deposit ratio (share of total paid online)
PLATFORM_COMMISSION_RATE="0.12"
DEPOSIT_RATE="0.20"
SERVICE_FEE_RATE="0.05"

# --- Notifications (Web Push / VAPID) ---
# generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:ops@nuzul.dz"
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""

# --- Media storage ---
# driver: local | s3
MEDIA_DRIVER="local"
S3_ENDPOINT=""
S3_BUCKET=""
S3_ACCESS_KEY=""
S3_SECRET_KEY=""

# --- App ---
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_DEFAULT_LOCALE="ar"
